# ==========================================
# Temple Booking Backend Environment Variables
# ==========================================

# Port to run the Express backend locally
PORT=3000

# Neon PostgreSQL Database Connection URL
# Format: postgresql://[user]:[password]@[host]/[dbname]?sslmode=require
DATABASE_URL=postgresql://user:password@host:5432/dbname?sslmode=require

# Enable SSL for Neon PostgreSQL (set to true)
DB_SSL=true

# Razorpay API Credentials
# Retrieve from Razorpay Dashboard -> Settings -> API Keys
RAZORPAY_KEY_ID=rzp_test_xxxxxxxxx
RAZORPAY_KEY_SECRET=xxxxxxxxxxxxxxxx

# Razorpay Webhook Secret for callback verification
# Retrieve from Razorpay Dashboard -> Webhooks -> Secret key
RAZORPAY_WEBHOOK_SECRET=webhook_secret_placeholder

# JWT Secret Key
# Generate a random, cryptographically secure 256-bit key
JWT_SECRET=temple_booking_jwt_secret_key_2026
